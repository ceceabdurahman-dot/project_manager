# ─── Server ───────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=ganti_dengan_string_acak_minimal_32_karakter
JWT_EXPIRES_IN=7d

# ─── Database ─────────────────────────────────────────
DB_PATH=../data/projectdb.sqlite

# ─── Upload ───────────────────────────────────────────
UPLOAD_PATH=../uploads
MAX_FILE_SIZE=10485760

# ─── Backup ───────────────────────────────────────────
BACKUP_PATH=../backups
BACKUP_RETAIN_DAYS=30

# ─── CORS (pisah dengan koma jika lebih dari satu) ────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

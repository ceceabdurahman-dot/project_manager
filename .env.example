# ─── Server ───────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Default aman: hanya akses dari komputer lokal.
# Untuk akses LAN, ubah ke 0.0.0.0 dan batasi firewall/CORS sesuai IP yang dipercaya.
SERVER_HOST=127.0.0.1

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=ganti_dengan_string_acak_minimal_32_karakter
JWT_EXPIRES_IN=8h

# ─── Database ─────────────────────────────────────────
DB_PATH=../data/projectdb.sqlite

# ─── Upload ───────────────────────────────────────────
UPLOAD_PATH=../uploads
MAX_FILE_SIZE=10485760

# ─── Backup ───────────────────────────────────────────
BACKUP_PATH=../backups
BACKUP_RETAIN_DAYS=30

# ─── CORS (pisah dengan koma jika lebih dari satu) ────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

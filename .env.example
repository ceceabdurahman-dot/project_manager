# ─── Server ───────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Untuk Hostinger / reverse proxy Node.js, gunakan 0.0.0.0.
SERVER_HOST=0.0.0.0

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=ganti_dengan_string_acak_minimal_32_karakter
JWT_EXPIRES_IN=8h
AUTH_COOKIE_SECURE=true

# ─── Database ─────────────────────────────────────────
DB_PATH=../data/projectdb.sqlite

# ─── Upload ───────────────────────────────────────────
UPLOAD_PATH=../uploads
MAX_FILE_SIZE=10485760

# ─── Backup ───────────────────────────────────────────
BACKUP_PATH=../backups
BACKUP_RETAIN_DAYS=30

# ─── CORS (pisah dengan koma jika lebih dari satu) ────
CORS_ORIGINS=https://proment.click,https://www.proment.click
